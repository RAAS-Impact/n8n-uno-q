# Copy this file to .env and fill in only the values you need. The
# orchestrator (scripts/run-integration.sh) sources .env automatically if
# it exists, so the same file works for both `npm run test:integration` and
# direct workspace test runs.
#
# Everything below is optional unless explicitly marked REQUIRED. The
# integration suites use sensible defaults for any variable left unset and
# skip whatever they can't run with — partial setups are fine.

# ─────────────────────────────────────────────────────────────────────────
# UNO Q transports (unix / tcp / mtls / ssh)
# ─────────────────────────────────────────────────────────────────────────
# These are the variables the orchestrator + the deploy scripts read. The
# defaults below match a single-board "linucs.local" lab setup; override
# only what differs in your environment.

# SSH target for the Q (used by the orchestrator's tunnel + by every
# deploy/*/install.sh script).
# UNOQ_HOST=arduino@linucs.local

# Base dir on the Q where install.sh deploys relay containers.
# UNOQ_BASE=/home/arduino

# Hostname the bridge connects to for the plain-TCP variant (must reach
# the Q on the LAN; doesn't need to match a cert).
# UNOQ_TCP_HOST=linucs.local

# Hostname the bridge connects to for mTLS — MUST match the SAN of the
# server cert issued by `./pki/pki add device <nick>` (typically <nick>.local).
# UNOQ_TLS_HOST=linucs.local

# PKI nicknames (must already exist under deploy/relay-mtls/pki/out/ and
# deploy/relay-ssh/pki/out/ respectively — generate via ./pki setup +
# ./pki add device <nick> + ./pki add n8n <nick> in each relay package).
# UNOQ_MTLS_DEVICE=linucs
# UNOQ_MTLS_N8N=laptop
# UNOQ_SSH_DEVICE=linucs
# UNOQ_SSH_N8N=laptop

# ─────────────────────────────────────────────────────────────────────────
# Arduino Cloud integration tests
# ─────────────────────────────────────────────────────────────────────────
# Generate API keys at https://app.arduino.cc/space-settings/api-keys.
# The Client Secret is shown only once — copy it then.
#
# REQUIRED to run any cloud test (the orchestrator skips the cloud step
# entirely when either is unset):
ARDUINO_CLOUD_CLIENT_ID=
ARDUINO_CLOUD_CLIENT_SECRET=

# Optional — set when your account belongs to multiple organizations and
# you want the SDK to scope requests to a specific one.
# ARDUINO_CLOUD_ORGANIZATION_ID=

# Optional — enables the listProperties / getProperty / historicData tests.
# Pick any Thing ID your account owns; the tests are read-only by default.
# ARDUINO_CLOUD_TEST_THING_ID=
# ARDUINO_CLOUD_TEST_PROPERTY_ID=

# Optional / opt-in — enables a single publishProperty test against this
# property. Only set this for a property you're happy to have written to
# during test runs (not bound to a physical actuator, etc.).
# ARDUINO_CLOUD_WRITE_PROPERTY_ID=
# ARDUINO_CLOUD_WRITE_VALUE=1.0

# Optional / opt-in — enables the live MQTT trigger end-to-end test.
# Pairs with ARDUINO_CLOUD_TEST_THING_ID; the value must match the
# variable_name (not the human-readable name) of one of that Thing's
# properties.
# ARDUINO_CLOUD_TRIGGER_VARIABLE_NAME=
