{
  "name": "@raasimpact/arduino-uno-q-bridge",
  "version": "0.4.0",
  "description": "Pure Node.js MessagePack-RPC client for the Arduino UNO Q router — read sensors, drive GPIO, and react to async MCU events from any Node.js process.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "arduino",
    "arduino-uno-q",
    "uno-q",
    "arduino-router",
    "messagepack-rpc",
    "msgpack-rpc",
    "msgpack",
    "mcu",
    "iot",
    "unix-socket",
    "rpc",
    "bridge"
  ],
  "author": "Lino Moretto <lino.moretto@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/raas-impact/n8n-uno-q#readme",
  "bugs": {
    "url": "https://github.com/raas-impact/n8n-uno-q/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raas-impact/n8n-uno-q.git",
    "directory": "packages/bridge"
  },
  "engines": {
    "node": ">=20"
  }
}
