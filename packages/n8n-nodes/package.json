{
  "name": "n8n-nodes-uno-q",
  "version": "0.1.0",
  "description": "n8n community nodes for Arduino UNO Q",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs && node scripts/copy-assets.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/UnoQCall/UnoQCall.node.js",
      "dist/nodes/UnoQTrigger/UnoQTrigger.node.js",
      "dist/nodes/UnoQTool/UnoQTool.node.js"
    ]
  },
  "dependencies": {
    "@raasimpact/arduino-uno-q-bridge": "*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "license": "MIT"
}
