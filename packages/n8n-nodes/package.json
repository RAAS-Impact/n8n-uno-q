{
  "name": "n8n-nodes-uno-q",
  "version": "0.1.1",
  "description": "n8n community nodes for the Arduino UNO Q — read sensors, drive GPIO, react to MCU events, and expose MCU methods as AI Agent tools.",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs && node scripts/copy-assets.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/UnoQCall/UnoQCall.node.js",
      "dist/nodes/UnoQTrigger/UnoQTrigger.node.js",
      "dist/nodes/UnoQRespond/UnoQRespond.node.js",
      "dist/nodes/UnoQTool/UnoQTool.node.js"
    ]
  },
  "dependencies": {
    "@raasimpact/arduino-uno-q-bridge": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "arduino",
    "arduino-uno-q",
    "uno-q",
    "mcu",
    "iot",
    "gpio",
    "i2c",
    "ai-agent",
    "tools-agent",
    "messagepack-rpc",
    "arduino-router"
  ],
  "author": "Lino Moretto <lino.moretto@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/raas-impact/n8n-uno-q#readme",
  "bugs": {
    "url": "https://github.com/raas-impact/n8n-uno-q/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raas-impact/n8n-uno-q.git",
    "directory": "packages/n8n-nodes"
  },
  "engines": {
    "node": ">=20"
  }
}
